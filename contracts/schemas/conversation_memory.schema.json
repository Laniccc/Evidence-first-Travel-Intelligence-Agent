{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/schemas/conversation_memory.schema.json",
  "title": "ConversationMemory",
  "description": "Session-level context for resolving deictic references (e.g. 这里/刚才那个).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "last_places": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "last_query": { "type": ["string", "null"] },
    "last_country": { "type": ["string", "null"] },
    "last_city": { "type": ["string", "null"] },
    "travel_date": { "type": ["string", "null"] },
    "recent_concerns": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
