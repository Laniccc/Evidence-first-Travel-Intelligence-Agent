{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/schemas/evidence.schema.json",
  "title": "Evidence",
  "description": "Single evidence unit produced by a tool or prior model.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "evidence_id",
    "source_name",
    "source_type",
    "claims",
    "confidence",
    "limitations"
  ],
  "properties": {
    "evidence_id": { "type": "string" },
    "source_name": { "type": "string" },
    "source_type": {
      "type": "string",
      "description": "e.g. official, map, weather_api, model_prior, unknown"
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/Claim" },
      "default": []
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "source_url": { "type": ["string", "null"] },
    "country": { "type": "string" },
    "city": { "type": ["string", "null"] },
    "place_name": { "type": ["string", "null"] }
  },
  "$defs": {
    "Claim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["claim_type", "value"],
      "properties": {
        "claim_type": { "type": "string" },
        "value": {},
        "raw_text": { "type": ["string", "null"] },
        "normalized_value": {},
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
