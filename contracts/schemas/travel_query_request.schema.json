{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/schemas/travel_query_request.schema.json",
  "title": "TravelQueryRequest",
  "description": "POST /api/travel/query request body.",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Natural-language travel question."
    },
    "session_id": {
      "type": "string",
      "description": "Optional client session identifier."
    },
    "user_context": {
      "type": "object",
      "description": "Optional session / user profile context.",
      "additionalProperties": true,
      "default": {}
    },
    "debug": {
      "type": "boolean",
      "description": "When true, response may include extended trace fields.",
      "default": false
    }
  }
}
