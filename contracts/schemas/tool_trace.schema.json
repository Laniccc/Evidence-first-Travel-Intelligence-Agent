{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/schemas/tool_trace.schema.json",
  "title": "ToolTrace",
  "description": "Record of a single tool invocation during evidence planning.",
  "type": "object",
  "additionalProperties": true,
  "required": ["tool_name", "status", "evidence_ids"],
  "properties": {
    "tool_name": { "type": "string" },
    "status": {
      "type": "string",
      "description": "e.g. ok, error, timeout"
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "error": { "type": ["string", "null"] },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "fallback_used": { "type": "boolean", "default": false },
    "cache_hit": { "type": "boolean", "default": false },
    "provider": { "type": ["string", "null"] },
    "configured": { "type": ["boolean", "null"] },
    "crawler_command": { "type": ["string", "null"] },
    "crawler_workdir": { "type": ["string", "null"] },
    "snapshot_saved_count": { "type": ["integer", "null"] },
    "output_parse_status": {
      "type": ["string", "null"],
      "description": "ok | non_json | parse_error"
    },
    "gap_filling": { "type": "boolean", "default": false },
    "gap_id": { "type": ["string", "null"] },
    "gap_claim_type": { "type": ["string", "null"] },
    "official_source_discovery": { "type": "boolean", "default": false },
    "urls_checked_count": { "type": ["integer", "null"] },
    "official_candidates_count": { "type": ["integer", "null"] },
    "top_source_classes": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  }
}
