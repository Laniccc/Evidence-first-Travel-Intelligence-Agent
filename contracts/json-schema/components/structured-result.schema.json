{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/json-schema/components/structured-result.schema.json",
  "title": "StructuredResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": { "type": ["string", "null"] },
    "recommendation": {
      "oneOf": [
        { "$ref": "recommendation-result.schema.json" },
        { "type": "null" }
      ]
    },
    "places": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "default": []
    },
    "comparison": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "comparison-row.schema.json" }
        },
        { "type": "null" }
      ]
    },
    "itinerary": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        { "type": "null" }
      ]
    }
  }
}
