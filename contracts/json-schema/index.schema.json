{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travel.intelligence/contracts/json-schema/index.schema.json",
  "title": "Travel Intelligence API Contracts",
  "description": "JSON Schema index for cross-language clients (Python FastAPI, Java Spring Boot).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1.0"
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "POST /api/travel/query": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "request": {
              "$ref": "travel-query.request.schema.json"
            },
            "response": {
              "$ref": "travel-query.response.schema.json"
            }
          }
        },
        "GET /health": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "response": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "version"],
              "properties": {
                "status": { "type": "string", "const": "ok" },
                "version": { "type": "string" }
              }
            }
          }
        },
        "GET /api/travel/supported-regions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "response": {
              "type": "object",
              "additionalProperties": false,
              "required": ["countries", "cities"],
              "properties": {
                "countries": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "cities": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
