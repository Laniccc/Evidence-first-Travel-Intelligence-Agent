# Copy to .env and export before `mvn spring-boot:run`, or set in your shell.
AGENT_BASE_URL=http://localhost:8001

# Tool Gateway / MCP (search_mcp)
TOOL_GATEWAY_ENABLED=true
MCP_ENABLED=false
MCP_SEARCH_ENABLED=false
MCP_SEARCH_SERVER_URL=
MCP_SEARCH_TOOL_NAME=public_web_search
MCP_TIMEOUT_SECONDS=30
