# DeepSeek API（Anthropic 兼容端点）
# 申请: https://platform.deepseek.com/
LLM_MODE=anthropic
LOG_LEVEL=INFO

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 兼容别名（未设 DEEPSEEK_API_KEY 时可填此项）
# ANTHROPIC_API_KEY=

# --- Real Data Pilot ---
# official/places/weather 是 legacy hybrid 工具，不是 MCP。
# ENABLE_REAL_OFFICIAL_PAGE=false → official 仅用 PLACE_REGISTRY mock（无中山陵等）
TOOL_MODE=real
ENABLE_REAL_WEATHER=false
ENABLE_REAL_PLACES=false
ENABLE_REAL_OFFICIAL_PAGE=false

# --- MCP Global ---
MCP_ENABLED=true
MCP_ENABLE_ALL=true
# search_only=仅已接通的 search_mcp（推荐）| full=同上（stub 仍关闭）| off=关 MCP 子服务
MCP_PROFILE=search_only
MCP_HTTP_AUTOSTART=true
MCP_HTTP_AUTOSTART_NEW_WINDOW=true
MCP_HTTP_AUTOSTART_KILL_STALE=true
MCP_HTTP_AUTOSTART_WAIT_SECONDS=8
MCP_MAX_TOOL_CALLS_PER_STATE=10

# Search: open-webSearch
# Repo: https://github.com/Aas-ee/open-webSearch
# Start: open-websearch serve
# Health: http://127.0.0.1:3210/health
MCP_SEARCH_ENABLED=true
MCP_SEARCH_TRANSPORT=open_websearch_http
MCP_SEARCH_SERVER_URL=http://127.0.0.1:3210
MCP_SEARCH_TOOL_NAME=search
# CN 推荐 baidu；海外可改 duckduckgo/bing。搜索超时单独加长（秒）
MCP_SEARCH_DEFAULT_ENGINE=baidu
MCP_SEARCH_TIMEOUT_SECONDS=30
MCP_SEARCH_USE_PROXY=false
MCP_SEARCH_PROXY_URL=http://127.0.0.1:7890

# Browser: Playwright MCP — adapter 未接，MCP_PROFILE=search_only 时不会进白名单
MCP_BROWSER_ENABLED=true
MCP_BROWSER_TRANSPORT=stdio
MCP_BROWSER_COMMAND=npx
MCP_BROWSER_ARGS=-y,@playwright/mcp@latest

# Open-Meteo
# Repo: https://github.com/cmer81/open-meteo-mcp
# Start HTTP: TRANSPORT=http PORT=3000 npx open-meteo-mcp-server
MCP_OPENMETEO_ENABLED=true
MCP_OPENMETEO_TRANSPORT=streamable_http
MCP_OPENMETEO_SERVER_URL=http://127.0.0.1:3000/mcp
MCP_OPENMETEO_TOOL_NAME=weather_forecast

# OSM
# Repo: https://github.com/jagan-shanmugam/open-streetmap-mcp
MCP_OSM_ENABLED=true
MCP_OSM_TRANSPORT=stdio
MCP_OSM_COMMAND=uvx
MCP_OSM_ARGS=osm-mcp-server

# Wikipedia
# Repo: https://github.com/cyanheads/wikipedia-mcp-server
MCP_WIKIPEDIA_ENABLED=true
MCP_WIKIPEDIA_TRANSPORT=stdio
MCP_WIKIPEDIA_COMMAND=npx
MCP_WIKIPEDIA_ARGS=-y,@cyanheads/wikipedia-mcp-server

# Wikidata
# Repo: https://github.com/zzaebok/mcp-wikidata
MCP_WIKIDATA_ENABLED=true
MCP_WIKIDATA_TRANSPORT=stdio
MCP_WIKIDATA_COMMAND=npx
MCP_WIKIDATA_ARGS=-y,mcp-wikidata

# Baidu Map MCP (独立于 MCP_PROFILE=search_only；需 AK)
# Docs: docs/baidu-map-mcp.md
# Remote: https://mcp.map.baidu.com/mcp?ak=YOUR_AK
BAIDU_MAP_AK=
MCP_BAIDU_MAP_ENABLED=false
MCP_BAIDU_MAP_TRANSPORT=baidu_streamable_http
MCP_BAIDU_MAP_SERVER_URL=https://mcp.map.baidu.com/mcp
MCP_BAIDU_MAP_SSE_URL=https://mcp.map.baidu.com/sse
MCP_BAIDU_MAP_TIMEOUT_SECONDS=10
MCP_BAIDU_MAP_STDIO_ENABLED=false
MCP_BAIDU_MAP_STDIO_COMMAND=npx
MCP_BAIDU_MAP_STDIO_ARGS=-y,@baidumap/mcp-server-baidu-map

# SQLite
# Repo: https://github.com/jparkerweb/mcp-sqlite
MCP_SQLITE_ENABLED=true
MCP_SQLITE_TRANSPORT=stdio
MCP_SQLITE_READONLY=true
MCP_SQLITE_COMMAND=npx
MCP_SQLITE_ARGS=-y,mcp-sqlite,./data/evidence_cache.db

OFFICIAL_PAGE_ALLOWED_DOMAINS=
BROWSER_ALLOWED_DOMAINS=
REAL_TOOL_TIMEOUT_SECONDS=8
REAL_TOOL_CACHE_TTL_SECONDS=3600

# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=

# Pilot geocoding via Nominatim (key gates real places tool)
PLACES_API_KEY=

# Place resolution: false = LLM + RealPlaces/MCP only (no mock catalog)
PLACE_RESOLUTION_USE_MOCK=false

# --- S5 Information Domain Framework ---
# Platform crawler / planner MCPs are placeholders only (not_implemented).
# Enable flags reserve future provider wiring; they do not activate real crawlers yet.
ENABLE_TICKET_PLATFORM_CRAWLERS=false
ENABLE_REVIEW_PLATFORM_CRAWLERS=false
ENABLE_TRAVEL_NOTE_CRAWLERS=false
ENABLE_NEARBY_PLATFORM_CRAWLERS=false
ENABLE_ITINERARY_PLANNER_TOOLS=false
ENABLE_CROWD_ESTIMATION_TOOLS=false

# --- Ticket / Review Providers (default off; enable in local .env) ---
TICKETLENS_ENABLED=false
TICKETLENS_MCP_URL=https://mcp.ticketlens.com/
TICKETLENS_API_BASE_URL=https://api.ticketlens.com/v1
TICKETLENS_API_KEY=
TICKETLENS_TIMEOUT_SECONDS=10

ENABLE_TICKET_CRAWLER_PROVIDERS=false
ENABLE_REVIEW_CRAWLER_PROVIDERS=false

CTRIP_CRAWLER_ENABLED=false
CTRIP_CRAWLER_COMMAND=
CTRIP_CRAWLER_WORKDIR=
CTRIP_CRAWLER_TIMEOUT_SECONDS=30
CTRIP_CRAWLER_MAX_RESULTS=20

FLIGGY_TICKET_CRAWLER_ENABLED=false
# 飞猪AI开放平台 https://flyai.open.fliggy.com/console — 接口密钥（sk- 开头，仅此一个）
FLIGGY_FLYAI_ENABLED=true
FLIGGY_FLYAI_API_KEY=
FLIGGY_FLYAI_CLI_COMMAND=npx --yes @fly-ai/flyai-cli@1.0.16
FLIGGY_FLYAI_TIMEOUT_SECONDS=30
# 可选：传统淘宝 TOP（open.fliggy.com 应用管理 App Key + App Secret）
FLIGGY_TOP_API_ENABLED=false
FLIGGY_APP_KEY=
FLIGGY_APP_SECRET=
FLIGGY_SESSION=
FLIGGY_API_GATEWAY_URL=https://gw.api.taobao.com/router/rest
FLIGGY_API_SIGN_METHOD=md5
FLIGGY_API_TIMEOUT_SECONDS=15
# 可选：本地爬虫 CLI 回退
FLIGGY_TICKET_CRAWLER_COMMAND=
FLIGGY_TICKET_CRAWLER_WORKDIR=
FLIGGY_TICKET_CRAWLER_TIMEOUT_SECONDS=30
FLIGGY_TICKET_CRAWLER_MAX_RESULTS=20

DIANPING_CRAWLER_ENABLED=false
DIANPING_CRAWLER_COMMAND=
DIANPING_CRAWLER_WORKDIR=
DIANPING_CRAWLER_TIMEOUT_SECONDS=30
DIANPING_CRAWLER_MAX_RESULTS=20

TICKET_SNAPSHOT_STORE_ENABLED=true
TICKET_SNAPSHOT_DB_PATH=./data/ticket_snapshots.sqlite3
