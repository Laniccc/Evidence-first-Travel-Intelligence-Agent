# DeepSeek API（Anthropic 兼容端点）
# 申请: https://platform.deepseek.com/
LLM_MODE=anthropic
LOG_LEVEL=INFO

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 兼容别名（未设 DEEPSEEK_API_KEY 时可填此项）
# ANTHROPIC_API_KEY=

# --- Real Data Pilot ---
# official/places/weather 是 legacy hybrid 工具，不是 MCP。
# ENABLE_REAL_OFFICIAL_PAGE=false → official 仅用 PLACE_REGISTRY mock（无中山陵等）
TOOL_MODE=hybrid
ENABLE_REAL_WEATHER=false
ENABLE_REAL_PLACES=false
ENABLE_REAL_OFFICIAL_PAGE=false

# --- MCP Global ---
MCP_ENABLED=true
MCP_ENABLE_ALL=true
# search_only=仅已接通的 search_mcp（推荐）| full=同上（stub 仍关闭）| off=关 MCP 子服务
MCP_PROFILE=search_only
MCP_HTTP_AUTOSTART=true
MCP_HTTP_AUTOSTART_NEW_WINDOW=true
MCP_HTTP_AUTOSTART_KILL_STALE=true
MCP_HTTP_AUTOSTART_WAIT_SECONDS=8

# Search: open-webSearch
# Repo: https://github.com/Aas-ee/open-webSearch
# Start: open-websearch serve
# Health: http://127.0.0.1:3210/health
MCP_SEARCH_ENABLED=true
MCP_SEARCH_TRANSPORT=open_websearch_http
MCP_SEARCH_SERVER_URL=http://127.0.0.1:3210
MCP_SEARCH_TOOL_NAME=search

# Browser: Playwright MCP — adapter 未接，MCP_PROFILE=search_only 时不会进白名单
MCP_BROWSER_ENABLED=true
MCP_BROWSER_TRANSPORT=stdio
MCP_BROWSER_COMMAND=npx
MCP_BROWSER_ARGS=-y,@playwright/mcp@latest

# Open-Meteo
# Repo: https://github.com/cmer81/open-meteo-mcp
# Start HTTP: TRANSPORT=http PORT=3000 npx open-meteo-mcp-server
MCP_OPENMETEO_ENABLED=true
MCP_OPENMETEO_TRANSPORT=streamable_http
MCP_OPENMETEO_SERVER_URL=http://127.0.0.1:3000/mcp
MCP_OPENMETEO_TOOL_NAME=weather_forecast

# OSM
# Repo: https://github.com/jagan-shanmugam/open-streetmap-mcp
MCP_OSM_ENABLED=true
MCP_OSM_TRANSPORT=stdio
MCP_OSM_COMMAND=uvx
MCP_OSM_ARGS=osm-mcp-server

# Wikipedia
# Repo: https://github.com/cyanheads/wikipedia-mcp-server
MCP_WIKIPEDIA_ENABLED=true
MCP_WIKIPEDIA_TRANSPORT=stdio
MCP_WIKIPEDIA_COMMAND=npx
MCP_WIKIPEDIA_ARGS=-y,@cyanheads/wikipedia-mcp-server

# Wikidata
# Repo: https://github.com/zzaebok/mcp-wikidata
MCP_WIKIDATA_ENABLED=true
MCP_WIKIDATA_TRANSPORT=stdio
MCP_WIKIDATA_COMMAND=npx
MCP_WIKIDATA_ARGS=-y,mcp-wikidata

# SQLite
# Repo: https://github.com/jparkerweb/mcp-sqlite
MCP_SQLITE_ENABLED=true
MCP_SQLITE_TRANSPORT=stdio
MCP_SQLITE_READONLY=true
MCP_SQLITE_COMMAND=npx
MCP_SQLITE_ARGS=-y,mcp-sqlite,./data/evidence_cache.db

OFFICIAL_PAGE_ALLOWED_DOMAINS=
BROWSER_ALLOWED_DOMAINS=
REAL_TOOL_TIMEOUT_SECONDS=8
REAL_TOOL_CACHE_TTL_SECONDS=3600

# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=

# Pilot geocoding via Nominatim (key gates real places tool)
PLACES_API_KEY=

# Place resolution: false = LLM + RealPlaces/MCP only (no mock catalog)
PLACE_RESOLUTION_USE_MOCK=false
