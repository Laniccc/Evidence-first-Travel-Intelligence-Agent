# DeepSeek API（Anthropic 兼容端点）
# 申请: https://platform.deepseek.com/
LLM_MODE=anthropic
LOG_LEVEL=INFO

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 兼容别名（未设 DEEPSEEK_API_KEY 时可填此项）
# ANTHROPIC_API_KEY=

# --- Real Data Pilot ---
TOOL_MODE=hybrid
ENABLE_REAL_WEATHER=false
ENABLE_REAL_PLACES=false
ENABLE_REAL_OFFICIAL_PAGE=false
MCP_ENABLED=false
REAL_TOOL_TIMEOUT_SECONDS=8
REAL_TOOL_CACHE_TTL_SECONDS=3600

# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=

# Pilot geocoding via Nominatim (key gates real places tool)
PLACES_API_KEY=

# Place resolution: false = LLM + RealPlaces/MCP only (no mock catalog)
PLACE_RESOLUTION_USE_MOCK=false
