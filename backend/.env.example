# DeepSeek API（Anthropic 兼容端点）
# 申请: https://platform.deepseek.com/
LLM_MODE=anthropic
LOG_LEVEL=INFO

# DEEPSEEK_API_KEY=  # 填写密钥；勿留空行 DEEPSEEK_API_KEY= 会屏蔽环境变量中的 key
DEEPSEEK_MODEL=deepseek-v4-flash
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 兼容别名（未设 DEEPSEEK_API_KEY 时可填此项）
# ANTHROPIC_API_KEY=

# --- Real Data Pilot ---
TOOL_MODE=hybrid
ENABLE_REAL_WEATHER=false
ENABLE_REAL_PLACES=false
ENABLE_REAL_OFFICIAL_PAGE=false
# 总开关：true 后还需为各 MCP_* 填写 ENABLED=true 与 SERVER_URL
MCP_ENABLED=true
MCP_SEARCH_ENABLED=false
MCP_SEARCH_SERVER_URL=
MCP_BROWSER_ENABLED=false
MCP_BROWSER_SERVER_URL=
MCP_OSM_ENABLED=false
MCP_OSM_SERVER_URL=
MCP_OPENMETEO_ENABLED=false
MCP_OPENMETEO_SERVER_URL=
MCP_WIKIPEDIA_ENABLED=false
MCP_WIKIPEDIA_SERVER_URL=
MCP_WIKIDATA_ENABLED=false
MCP_WIKIDATA_SERVER_URL=
MCP_SQLITE_ENABLED=false
MCP_SQLITE_SERVER_URL=
MCP_SQLITE_READONLY=true
MCP_TIMEOUT_SECONDS=10
MCP_MAX_RESULT_CHARS=6000
MCP_MAX_TOOL_CALLS_PER_STATE=5
OFFICIAL_PAGE_ALLOWED_DOMAINS=
BROWSER_ALLOWED_DOMAINS=
REAL_TOOL_TIMEOUT_SECONDS=8
REAL_TOOL_CACHE_TTL_SECONDS=3600

# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=

# Pilot geocoding via Nominatim (key gates real places tool)
PLACES_API_KEY=

# Place resolution: false = LLM + RealPlaces/MCP only (no mock catalog)
PLACE_RESOLUTION_USE_MOCK=false
